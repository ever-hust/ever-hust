{
  "name": "ever-hust",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "test": "node --max-old-space-size=4096 --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.ts",
    "test:e2e": "playwright test",
    "db:push": "pnpm --filter @ever-hust/db db:push",
    "db:migrate": "pnpm --filter @ever-hust/db db:migrate",
    "db:seed": "pnpm --filter @ever-hust/db db:seed",
    "db:studio": "pnpm --filter @ever-hust/db db:studio",
    "db:generate": "pnpm --filter @ever-hust/db db:generate"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "prettier": "^3.7.4",
    "ts-jest": "^29.4.6",
    "turbo": "^2.7.1",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  }
}
