# =============================================================================
# Ever Jobs - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values

# -----------------------------------------------------------------------------
# Supabase (Database + Realtime + Storage)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# BetterAuth
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=your-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# LinkedIn OAuth
# -----------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=your-linkedin-app-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-app-client-secret

# -----------------------------------------------------------------------------
# AI (Vercel AI SDK → OpenRouter)
# -----------------------------------------------------------------------------
# Primary: OpenRouter routes LLM requests to any provider (recommended)
OPENROUTER_API_KEY=sk-or-v1-...

# Fallback: Direct Anthropic API (used when OpenRouter not configured, or BYOK)
ANTHROPIC_API_KEY=your-anthropic-api-key
DEFAULT_AI_MODEL=claude-sonnet-4-20250514

# Optional: Additional AI providers for BYOK
# OPENAI_API_KEY=your-openai-api-key
# GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key

# -----------------------------------------------------------------------------
# Langfuse (Prompt Management + LLM Observability)
# Optional: Falls back to hardcoded prompts when not configured
# Get keys at https://cloud.langfuse.com
# -----------------------------------------------------------------------------
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# Ever Jobs API (External - deployed in k8s)
# -----------------------------------------------------------------------------
EVER_JOBS_API_URL=https://api.everjobs.ai
EVER_JOBS_API_KEY=your-ever-jobs-api-key

# -----------------------------------------------------------------------------
# Stripe (Payments)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_QUARTERLY_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# -----------------------------------------------------------------------------
# Trigger.dev (Background Jobs)
# -----------------------------------------------------------------------------
TRIGGER_SECRET_KEY=tr_dev_...

# -----------------------------------------------------------------------------
# Resend (Email)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=alerts@everjobs.ai

# -----------------------------------------------------------------------------
# Upstash Redis (Rate Limiting)
# Optional: Falls back to in-memory rate limiting when not configured
# -----------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Ever Jobs
