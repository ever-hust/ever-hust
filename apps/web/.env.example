# =============================================================================
# Ever Jobs - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
#
# Legend:
#   [REQUIRED]  — Must be set for the app to start
#   [OPTIONAL]  — Has a sensible default or gracefully falls back
#   [DEV-ONLY]  — Only needed in specific development/CI scenarios

# -----------------------------------------------------------------------------
# Database (Drizzle ORM + Supabase PostgreSQL)
# -----------------------------------------------------------------------------

# [REQUIRED] PostgreSQL connection string (used by Drizzle ORM & BetterAuth)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Supabase (Realtime + Storage + Auth helpers)
# -----------------------------------------------------------------------------

# [REQUIRED] Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED] Supabase anonymous/public key (safe to expose client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# [OPTIONAL] Supabase service role key (server-side only, bypasses RLS)
# Required for server-side Supabase operations (storage, realtime admin, etc.)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Authentication (BetterAuth v1)
# -----------------------------------------------------------------------------

# [REQUIRED] Random secret for signing session cookies (min 32 chars)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-random-secret-at-least-32-chars

# [REQUIRED] Base URL for BetterAuth callback redirects
BETTER_AUTH_URL=http://localhost:8443

# -----------------------------------------------------------------------------
# LinkedIn OAuth
# -----------------------------------------------------------------------------

# [REQUIRED] LinkedIn app credentials from https://developer.linkedin.com
LINKEDIN_CLIENT_ID=your-linkedin-app-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-app-client-secret

# -----------------------------------------------------------------------------
# GitHub OAuth (Social Account Linking)
# Optional in dev, required in production. Users can link their GitHub account
# after initial LinkedIn registration to enable GitHub sign-in.
# Create an OAuth app at https://github.com/settings/developers
# Redirect URL: {BETTER_AUTH_URL}/api/auth/callback/github
# -----------------------------------------------------------------------------

# [OPTIONAL] GitHub OAuth app credentials
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# -----------------------------------------------------------------------------
# Google OAuth (Social Account Linking)
# Optional in dev, required in production.
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# Redirect URL: {BETTER_AUTH_URL}/api/auth/callback/google
# -----------------------------------------------------------------------------

# [OPTIONAL] Google OAuth client credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# -----------------------------------------------------------------------------
# Facebook OAuth (Social Account Linking)
# Optional in dev, required in production.
# Create an app at https://developers.facebook.com
# Redirect URL: {BETTER_AUTH_URL}/api/auth/callback/facebook
# -----------------------------------------------------------------------------

# [OPTIONAL] Facebook OAuth app credentials
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret

# -----------------------------------------------------------------------------
# Twitter/X OAuth (Social Account Linking)
# Optional in dev, required in production.
# Create a project at https://developer.twitter.com
# Redirect URL: {BETTER_AUTH_URL}/api/auth/callback/twitter
# -----------------------------------------------------------------------------

# [OPTIONAL] Twitter/X OAuth app credentials
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# -----------------------------------------------------------------------------
# AI (Vercel AI SDK)
# At least one of OPENROUTER_API_KEY or ANTHROPIC_API_KEY must be set.
# -----------------------------------------------------------------------------

# [OPTIONAL] OpenRouter API key — primary provider, routes to any LLM
# Recommended for production. Get one at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# [OPTIONAL] Anthropic API key — fallback provider & BYOK direct access
ANTHROPIC_API_KEY=your-anthropic-api-key

# [OPTIONAL] Default AI model for paid-tier users
# Defaults to "claude-sonnet-4-20250514" if not set
DEFAULT_AI_MODEL=claude-sonnet-4-20250514

# [OPTIONAL] Additional AI providers for BYOK (Bring Your Own Key) users
# OPENAI_API_KEY=your-openai-api-key
# GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key

# -----------------------------------------------------------------------------
# BYOK Encryption (API Key Encryption at Rest)
# -----------------------------------------------------------------------------

# [OPTIONAL] 256-bit hex key for encrypting user-provided API keys in the DB
# Required if the BYOK feature is enabled.
# Generate with: openssl rand -hex 32
BYOK_ENCRYPTION_KEY=your-random-hex-string-at-least-32-chars

# -----------------------------------------------------------------------------
# Langfuse (Prompt Management + LLM Observability)
# Optional: Falls back to hardcoded prompts when not configured.
# Get keys at https://cloud.langfuse.com
# -----------------------------------------------------------------------------

# [OPTIONAL] Langfuse public key for client-side telemetry
# LANGFUSE_PUBLIC_KEY=pk-lf-...

# [OPTIONAL] Langfuse secret key for server-side prompt fetching
# LANGFUSE_SECRET_KEY=sk-lf-...

# [OPTIONAL] Langfuse base URL (defaults to https://cloud.langfuse.com)
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# Ever Jobs API (External job data — deployed in k8s)
# -----------------------------------------------------------------------------

# [OPTIONAL] Base URL of the Ever Jobs external API
EVER_JOBS_API_URL=https://api.everjobs.ai

# [OPTIONAL] API key for authenticating with the Ever Jobs external API
EVER_JOBS_API_KEY=your-ever-jobs-api-key

# -----------------------------------------------------------------------------
# Stripe (Payments & Subscriptions)
# -----------------------------------------------------------------------------

# [REQUIRED] Stripe secret key for server-side API calls
STRIPE_SECRET_KEY=sk_test_...

# [REQUIRED] Stripe webhook signing secret for verifying webhook events
STRIPE_WEBHOOK_SECRET=whsec_...

# [REQUIRED] Stripe publishable key for client-side Stripe.js (safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# [OPTIONAL] Stripe Price IDs for subscription plans
# These map to your Stripe dashboard price objects
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_QUARTERLY_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...

# -----------------------------------------------------------------------------
# Trigger.dev (Background Jobs — job sync, alerts, cleanup)
# -----------------------------------------------------------------------------

# [OPTIONAL] Trigger.dev secret key (optional in local dev)
TRIGGER_SECRET_KEY=tr_dev_...

# -----------------------------------------------------------------------------
# Resend (Transactional Email)
# -----------------------------------------------------------------------------

# [REQUIRED] Resend API key for sending emails
RESEND_API_KEY=re_...

# [OPTIONAL] Sender address for outgoing emails (defaults to "alerts@hust.so")
EMAIL_FROM=alerts@hust.so

# -----------------------------------------------------------------------------
# Upstash Redis (Distributed Rate Limiting)
# Optional: Falls back to in-memory rate limiting when not configured.
# Recommended for production with multiple instances.
# -----------------------------------------------------------------------------

# [OPTIONAL] Upstash Redis REST URL
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io

# [OPTIONAL] Upstash Redis REST token
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# -----------------------------------------------------------------------------
# Rate limiter — @ever-hust/rate-limit (daily free-tier message cap)
# Default driver is in-memory (per-pod). Set a Redis URL to make the cap
# distributed across pods. Disabled by default. See packages/rate-limit/README.md.
# When enabling: `pnpm --filter web add ioredis` first.
# -----------------------------------------------------------------------------

# [OPTIONAL] TCP Redis connection string (DigitalOcean Managed Redis, self-hosted, Valkey…).
# Its presence flips the limiter to the Redis driver.
# RATE_LIMIT_REDIS_URL=rediss://default:password@host.db.ondigitalocean.com:25061/0

# [OPTIONAL] Force a driver explicitly: "memory" | "redis" (overrides URL detection).
# RATE_LIMIT_DRIVER=redis

# [OPTIONAL] Redis key namespace (default: everhust:rl:)
# RATE_LIMIT_PREFIX=everhust:rl:

# -----------------------------------------------------------------------------
# Google Maps (Maps JavaScript API + Geocoding API)
# Optional: Map view disabled when not configured.
# Enable "Maps JavaScript API" and "Geocoding API" in Google Cloud Console.
# -----------------------------------------------------------------------------

# [OPTIONAL] Google Maps API key for map view of job listings
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------

# [OPTIONAL] Public-facing app URL (defaults to "https://hust.so" in prod)
NEXT_PUBLIC_APP_URL=http://localhost:8443

# [OPTIONAL] Display name for the app (defaults to "Hust")
NEXT_PUBLIC_APP_NAME=Hust

# -----------------------------------------------------------------------------
# Push Notifications (Web Push / VAPID)
# -----------------------------------------------------------------------------

# [OPTIONAL] VAPID public key for web push subscription registration
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------

# [OPTIONAL] Bearer token to access the detailed /api/health endpoint
# When set, the health check endpoint requires this token for full diagnostics
# HEALTH_CHECK_TOKEN=your-health-check-token

# -----------------------------------------------------------------------------
# Vercel / CI (automatically set in deployed environments)
# -----------------------------------------------------------------------------

# [DEV-ONLY] Set to "true" to generate bundle analysis report with build
# ANALYZE=true

# These are set automatically by Vercel — no need to configure manually:
# VERCEL_GIT_COMMIT_SHA — used in health endpoint to report deploy version
# NODE_ENV — "development" locally, "production" in Vercel
